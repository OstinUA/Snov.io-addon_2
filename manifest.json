{
  "manifest_version": 3,
  "name": "Snov.io addon_2dev",
  "version": "1.2.0",
  "description": "Click the copy icon to instantly compose an email | adWMG / by Ostin",
  "icons": {
      "128": "icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://app.snov.io/*"
  ],
  "content_scripts": [
    {
      "matches": [ "https://app.snov.io/*" ],
      "js": [ "content.js" ],
      "run_at": "document_end"
    }
  ]
}